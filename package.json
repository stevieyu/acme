{
  "name": "@stvy/acme",
  "version": "0.1.0",
  "description": "Pure TypeScript ACME v2 client SDK with DNS-01 challenge support for 167 DNS providers",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "tsc --noEmit",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "keywords": [
    "acme",
    "letsencrypt",
    "ssl",
    "tls",
    "certificate",
    "dns-01",
    "dns"
  ],
  "license": "MIT",
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "fast-xml-parser": "^4.5.6"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsdown": "latest",
    "typescript": "7.0.1-rc"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs"
}
